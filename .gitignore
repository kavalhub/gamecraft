# Laravel стандартный .gitignore
/.phpunit.cache
/.pail
/build
/public/build
/public/hot
/public/storage
/storage/*.key
/vendor
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log
/fleet
/.fleet
/.idea
/.vscode

# Игровые специфичные
/storage/logs/*
!/storage/logs/.gitignore
/bootstrap/cache/*
!/bootstrap/cache/.gitignore
/scripts/api_bot_smoke_test.py
